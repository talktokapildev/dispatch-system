{
  "expo": {
    "name": "OrangeRide",
    "newArchEnabled": false,
    "slug": "orangeride-passenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090d14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.orangeride.passenger",
      "buildNumber": "7",
      "entitlements": {
        "com.apple.developer.in-app-payments": [
          "merchant.com.orangeride.passenger"
        ]
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "OrangeRide needs your location to find drivers near you and track your ride.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "OrangeRide needs your location to track your ride.",
        "NSLocationAlwaysUsageDescription": "OrangeRide needs your location to track your ride.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "OrangeRide uses your camera for profile photos and document verification if required.",
        "NSPhotoLibraryUsageDescription": "OrangeRide uses your photo library for profile photos and document verification if required."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyAACxY0v2BlKtyW2BnNRjnGpuM1UjrRGWI"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090d14"
      },
      "package": "com.orangeride.passenger",
      "versionCode": 4,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAACxY0v2BlKtyW2BnNRjnGpuM1UjrRGWI"
        }
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow OrangeRide to use your location for pickup and ride tracking."
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.orangeride.passenger",
          "enableGooglePay": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b8e163a5-e65b-4428-b5b3-27a184eac632"
      }
    },
    "owner": "orangeride"
  }
}
