// ─────────────────────────────────────────
// PRICING CONFIG (single configurable row)
// ─────────────────────────────────────────

model PricingConfig {
  id                       String   @id @default(uuid())

  // ── Base fare components ──────────────────
  baseFare                 Float    @default(3.50)
  perMile                  Float    @default(1.80)
  perMinute                Float    @default(0.20)
  minimumFare              Float    @default(15.00)

  // ── Commission ────────────────────────────
  // Operator takes 15%, drivers keep 85%
  platformCommission       Float    @default(0.15)

  // ── Time premiums (as decimals, 0.25 = 25%) ──
  nightPremium             Float    @default(0.25)
  nightStartHour           Int      @default(23)   // 23:00
  nightEndHour             Int      @default(6)    // 06:00
  bankHolidayPremium       Float    @default(0.25)
  christmasNyePremium      Float    @default(0.75) // Dec 24-26, Dec 31

  // ── Airport fees (£, pass-through) ────────
  gatwickDropoff           Float    @default(10.00)
  gatwickPickup            Float    @default(10.00)
  heathrowDropoff          Float    @default(7.00)
  heathrowPickup           Float    @default(7.00)
  meetAndGreet             Float    @default(12.00)

  // ── Other pass-throughs (£) ───────────────
  dartfordCrossing         Float    @default(2.50)
  congestionCharge         Float    @default(15.00)
  // ULEZ is £0 for Tesla — omitted intentionally

  // ── Extras ────────────────────────────────
  extraStopCharge          Float    @default(5.00)
  freeWaitingMinutes       Int      @default(10)
  waitingRatePerMinute     Float    @default(0.50)

  // ── Cancellation policy ───────────────────
  retailCancelFreeMinutes  Int      @default(15)   // Free within 15 min of booking
  accountCancelFreeHours   Int      @default(2)    // Free up to 2 hrs before pickup

  // ── Care home distance bands (£) ─────────
  careHomeUnder3miles      Float    @default(15.00)
  careHome3to7miles        Float    @default(22.00)
  careHome7to15miles       Float    @default(32.00)
  careHome15to25miles      Float    @default(48.00)
  careHome25to40miles      Float    @default(70.00)
  careHomeHospitalDischarge Float   @default(10.00) // supplement
  careHomeHalfDay          Float    @default(150.00)
  careHomeFullDay          Float    @default(250.00)
  careHomeHourlyBeyondFull Float    @default(35.00)

  updatedAt                DateTime @updatedAt
  updatedBy                String?
}


// ─────────────────────────────────────────
// DRIVER EARNINGS
// ─────────────────────────────────────────

model DriverEarning {
  id          String   @id @default(uuid())
  driverId    String
  bookingId   String   @unique
  grossAmount Float
  platformFee Float
  netAmount   Float
  paidOut     Boolean  @default(false)
  paidOutAt   DateTime?
  createdAt   DateTime @default(now())

  driver      Driver   @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@index([paidOut])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  sentAt    DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String   // ios | android
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}

// ─────────────────────────────────────────
// SURCHARGE ZONES
// ─────────────────────────────────────────

model SurchargeZone {
  id            String   @id @default(uuid())
  name          String   // "London Gatwick South Terminal"
  type          String   @default("OTHER") // AIRPORT | HOTEL | VENUE | OTHER
  latitude      Float
  longitude     Float
  radiusMeters  Int      @default(500)  // detection radius
  pickupFee     Float    @default(0)
  dropoffFee    Float    @default(0)
  isActive      Boolean  @default(true)
  notes         String?  // internal notes e.g. "Hilton access fee — pass-through only"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}
