generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum LostPropertyStatus {
  REPORTED
  FOUND
  RETURNED
  CLOSED
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
  DISPATCHER
  CORPORATE_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DRIVER_ASSIGNED
  DRIVER_EN_ROUTE
  DRIVER_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingType {
  ASAP
  PREBOOKED
  AIRPORT_PICKUP
  AIRPORT_DROPOFF
  CORPORATE
  CAREHOME 
}

enum PricingType {
  FIXED
  METERED
}

enum PaymentMethod {
  CARD
  CASH
  APPLE_PAY
  GOOGLE_PAY
  ACCOUNT
  INVOICE
}

enum PaymentStatus {
  PENDING
  AUTHORISED
  CAPTURED
  REFUNDED
  FAILED
  CASH
}

enum DriverStatus {
  OFFLINE
  AVAILABLE
  ON_JOB
  BREAK
}

enum VehicleClass {
  STANDARD
  EXECUTIVE
  MPV
  MINIBUS
}

enum DocumentType {
  PCO_LICENSE
  DRIVING_LICENSE
  VEHICLE_INSURANCE
  MOT_CERTIFICATE
  V5C_LOGBOOK
  DBS_CHECK
  PROFILE_PHOTO
  VEHICLE_PHOTO
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum CorporateInvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum CareHomeAccountStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum ResidentMobility {
  AMBULATORY
  WALKING_AID
  WHEELCHAIR
  WHEELCHAIR_ASSIST
  STRETCHER
}

enum RecurrencePattern {
  DAILY
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

// ─────────────────────────────────────────
// CORE USER
// ─────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  email         String?   @unique
  firstName     String
  lastName      String
  role          UserRole
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  passenger          Passenger?
  driver             Driver?
  adminProfile       AdminProfile?
  otpCodes           OtpCode[]
  refreshTokens      RefreshToken[]
  dispatchedBookings Booking[]     @relation("BookingDispatcher")

  @@index([phone])
  @@index([email])
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─────────────────────────────────────────
// PASSENGER
// ─────────────────────────────────────────

model Passenger {
  id                 String    @id @default(uuid())
  userId             String    @unique
  stripeCustomerId   String?
  savedAddresses     Json      @default("[]")
  corporateAccountId String?
  totalRides         Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  lostProperties     LostProperty[]

  user             User              @relation(fields: [userId], references: [id])
  corporateAccount CorporateAccount? @relation(fields: [corporateAccountId], references: [id])
  bookings         Booking[]
  paymentMethods   SavedPaymentMethod[]

  @@index([userId])
}

model SavedPaymentMethod {
  id                    String    @id @default(uuid())
  passengerId           String
  stripePaymentMethodId String
  brand                 String
  last4                 String
  expiryMonth           Int
  expiryYear            Int
  isDefault             Boolean   @default(false)
  createdAt             DateTime  @default(now())

  passenger Passenger @relation(fields: [passengerId], references: [id])
}

// ─────────────────────────────────────────
// DRIVER
// ─────────────────────────────────────────

model Driver {
  id                   String       @id @default(uuid())
  userId               String       @unique
  pcoBadgeNumber       String       @unique
  pcoLicenseExpiry     DateTime
  drivingLicenseNumber String
  status               DriverStatus @default(OFFLINE)
  currentLatitude      Float?
  currentLongitude     Float?
  currentBearing       Float?
  lastLocationAt       DateTime?
  rating               Float        @default(5.0)
  totalJobs            Int          @default(0)
  stripeAccountId      String?
  onboardingComplete   Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user      User             @relation(fields: [userId], references: [id])
  vehicle   Vehicle?
  documents DriverDocument[]
  bookings  Booking[]
  earnings  DriverEarning[]
  breaks    DriverBreak[]

  @@index([userId])
  @@index([status])
}

model Vehicle {
  id               String       @id @default(uuid())
  driverId         String       @unique
  make             String
  model            String
  year             Int
  colour           String
  licensePlate     String       @unique
  phvLicenceNumber String?
  phvLicenceExpiry DateTime?
  phvDiscNumber    String?
  class            VehicleClass @default(STANDARD)
  seats            Int          @default(4)
  motExpiry        DateTime
  insuranceExpiry  DateTime
  emissionStandard String?      // e.g. "Euro 6", "Electric", "Hybrid"
  isUlezCompliant  Boolean      @default(false)

  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])
}

model DriverDocument {
  id         String         @id @default(uuid())
  driverId   String
  type       DocumentType
  status     DocumentStatus @default(PENDING)
  fileUrl    String
  expiryDate DateTime?
  notes      String?
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@index([status])
  @@index([expiryDate])
}

model DriverBreak {
  id        String    @id @default(uuid())
  driverId  String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  driver Driver @relation(fields: [driverId], references: [id])
}

// ─────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())

   // TfL Condition 19: staff register
  dateOfBirth          DateTime?
  dbsCertificateNumber String?
  dbsCheckDate         DateTime?

  user User @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// CORPORATE ACCOUNTS
// ─────────────────────────────────────────

model CorporateAccount {
  id               String   @id @default(uuid())
  name             String                    // renamed from companyName
  contactName      String
  contactEmail     String
  contactPhone     String
  address          String
  invoicingEmail   String
  paymentTermsDays Int      @default(30)
  creditLimit      Float    @default(0)
  currentBalance   Float    @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  passengers Passenger[]
  bookings   Booking[]
  invoices   CorporateInvoice[]

  @@index([name])
}

model CorporateInvoice {
  id                 String                 @id @default(uuid())
  corporateAccountId String
  invoiceNumber      String                 @unique
  periodFrom         DateTime
  periodTo           DateTime
  totalAmount        Float
  status             CorporateInvoiceStatus @default(DRAFT)
  dueDate            DateTime
  paidAt             DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  corporateAccount CorporateAccount @relation(fields: [corporateAccountId], references: [id])
  bookings         Booking[]

  @@index([corporateAccountId])
}

// ─────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────

model Booking {
  id                 String        @id @default(uuid())
  reference          String        @unique
  passengerId        String?
  driverId           String?
  corporateAccountId String?
  corporateInvoiceId String?

  type   BookingType
  status BookingStatus @default(PENDING)

  // Locations
  pickupAddress    String
  pickupLatitude   Float
  pickupLongitude  Float
  dropoffAddress   String
  dropoffLatitude  Float
  dropoffLongitude Float
  stops            Json   @default("[]")

  // Timing
  scheduledAt      DateTime?
  dispatchedAt     DateTime?
  driverAcceptedAt DateTime?
  driverArrivedAt  DateTime?
  tripStartedAt    DateTime?
  completedAt      DateTime?

  // TfL Compliance: dispatcher record (Condition 6)
  dispatchedBy String?

  // Pricing
  pricingType     PricingType   @default(FIXED)
  estimatedFare   Float
  actualFare      Float?
  surgeMultiplier Float         @default(1.0)
  driverEarning   Float?
  platformFee     Float?

  // Payment
  paymentMethod         PaymentMethod @default(CARD)
  paymentStatus         PaymentStatus @default(PENDING)
  stripePaymentIntentId String?

  // Flight details
  flightNumber      String?
  flightArrivalTime DateTime?
  terminal          String?

  // Misc
  passengerCount     Int     @default(1)
  notes              String?
  operatorNotes      String?
  cancellationReason String?
  rating             Int?
  feedback           String?
  dispatchAttempts   Int     @default(0)

  // Quick-win fields
  pickupZone             String?
  dropoffZone            String?
  fixedPriceOverride     Float?
  isOnHold               Boolean   @default(false)
  allocationTime         DateTime?
  requiredCarFeatures    Json      @default("[]")
  requiredDriverFeatures Json      @default("[]")
  department             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lostProperties LostProperty[]

  passenger        Passenger?         @relation(fields: [passengerId], references: [id])
  driver           Driver?           @relation(fields: [driverId], references: [id])
  corporateAccount CorporateAccount? @relation(fields: [corporateAccountId], references: [id])
  corporateInvoice CorporateInvoice? @relation(fields: [corporateInvoiceId], references: [id])
  statusHistory    BookingStatusHistory[]
  receipt          Receipt?
  dispatchedByUser User?             @relation("BookingDispatcher", fields: [dispatchedBy], references: [id])

  // care home
  careHomeId         String?
  careHome           CareHomeAccount?  @relation(fields: [careHomeId], references: [id])
  residentId         String?
  resident           CareHomeResident? @relation(fields: [residentId], references: [id])
  recurringBookingId String?
  recurringBooking   RecurringBooking? @relation(fields: [recurringBookingId], references: [id])
  careHomeInvoiceId  String?
  careHomeInvoice    CareHomeInvoice?  @relation(fields: [careHomeInvoiceId], references: [id])

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
  @@index([scheduledAt])
  @@index([reference])
  @@index([dispatchedBy])
}

model BookingStatusHistory {
  id        String        @id @default(uuid())
  bookingId String
  status    BookingStatus
  note      String?
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Receipt {
  id                    String   @id @default(uuid())
  bookingId             String   @unique
  receiptNumber         String   @unique
  operatorName          String
  operatorLicenseNumber String
  driverName            String
  driverPcoBadge        String
  vehiclePlate          String
  vehicleDescription    String
  pickupAddress         String
  dropoffAddress        String
  tripDistance          Float?
  tripDuration          Int?
  fareBreakdown         Json
  totalAmount           Float
  paymentMethod         String
  issuedAt              DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

// ─────────────────────────────────────────
// PRICING CONFIG
// ─────────────────────────────────────────

model PricingConfig {
  id String @id @default(uuid())

  baseFare    Float @default(3.50)
  perMile     Float @default(1.80)
  perMinute   Float @default(0.20)
  minimumFare Float @default(15.00)

  platformCommission Float @default(0.15)

  nightPremium        Float @default(0.25)
  nightStartHour      Int   @default(23)
  nightEndHour        Int   @default(6)
  bankHolidayPremium  Float @default(0.25)
  christmasNyePremium Float @default(0.75)

  gatwickDropoff  Float @default(10.00)
  gatwickPickup   Float @default(10.00)
  heathrowDropoff Float @default(7.00)
  heathrowPickup  Float @default(7.00)
  meetAndGreet    Float @default(12.00)

  dartfordCrossing Float @default(2.50)
  congestionCharge Float @default(15.00)

  extraStopCharge      Float @default(5.00)
  freeWaitingMinutes   Int   @default(10)
  waitingRatePerMinute Float @default(0.50)

  retailCancelFreeMinutes Int @default(15)
  accountCancelFreeHours  Int @default(2)

  careHomeUnder3miles       Float @default(15.00)
  careHome3to7miles         Float @default(22.00)
  careHome7to15miles        Float @default(32.00)
  careHome15to25miles       Float @default(48.00)
  careHome25to40miles       Float @default(70.00)
  careHomeHospitalDischarge Float @default(10.00)
  careHomeHalfDay           Float @default(150.00)
  careHomeFullDay           Float @default(250.00)
  careHomeHourlyBeyondFull  Float @default(35.00)

  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─────────────────────────────────────────
// DRIVER EARNINGS
// ─────────────────────────────────────────

model DriverEarning {
  id          String    @id @default(uuid())
  driverId    String
  bookingId   String    @unique
  grossAmount Float
  platformFee Float
  netAmount   Float
  paidOut     Boolean   @default(false)
  paidOutAt   DateTime?
  createdAt   DateTime  @default(now())

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@index([paidOut])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id     String   @id @default(uuid())
  userId String
  title  String
  body   String
  data   Json?
  read   Boolean  @default(false)
  sentAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}

// ─────────────────────────────────────────
// SURCHARGE ZONES
// ─────────────────────────────────────────

model SurchargeZone {
  id           String   @id @default(uuid())
  name         String
  type         String   @default("OTHER")
  latitude     Float
  longitude    Float
  radiusMeters Int      @default(500)
  pickupFee    Float    @default(0)
  dropoffFee   Float    @default(0)
  isActive     Boolean  @default(true)
  notes        String?
  polygon      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model LostProperty {
  id           String             @id @default(uuid())
  bookingId    String
  passengerId  String
  description  String
  contactPhone String
  status       LostPropertyStatus @default(REPORTED)
  adminNotes   String?
  reportedAt   DateTime           @default(now())
  resolvedAt   DateTime?
  booking      Booking            @relation(fields: [bookingId], references: [id])
  passenger    Passenger          @relation(fields: [passengerId], references: [id])
  @@index([bookingId])
  @@index([passengerId])
  @@index([status])
}



// ─────────────────────────────────────────
// CARE HOME 
// ─────────────────────────────────────────
model CareHomeAccount {
  id               String                @id @default(cuid())
  name             String
  address          String
  contactName      String
  contactEmail     String
  contactPhone     String
  invoicingEmail   String
  paymentTermsDays Int                   @default(30)
  status           CareHomeAccountStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  residents        CareHomeResident[]
  bookings         Booking[]
  invoices         CareHomeInvoice[]
  staff            CareHomeStaff[]
  recurringBookings RecurringBooking[]
}

model CareHomeStaff {
  id           String          @id @default(cuid())
  careHomeId   String
  careHome     CareHomeAccount @relation(fields: [careHomeId], references: [id])
  name         String
  email        String          @unique
  phone        String?
  passwordHash String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model CareHomeResident {
  id            String           @id @default(cuid())
  careHomeId    String
  careHome      CareHomeAccount  @relation(fields: [careHomeId], references: [id])
  name          String
  dateOfBirth   DateTime?
  mobility      ResidentMobility @default(AMBULATORY)
  accessNotes   String?
  medicalNotes  String?
  contactName   String?
  contactPhone  String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  bookings          Booking[]
  recurringBookings RecurringBooking[]
}

model RecurringBooking {
  id               String          @id @default(cuid())
  careHomeId       String
  careHome         CareHomeAccount @relation(fields: [careHomeId], references: [id])
  residentId       String
  resident         CareHomeResident @relation(fields: [residentId], references: [id])
  pickupAddress    String
  pickupLat        Float?
  pickupLng        Float?
  dropoffAddress   String
  dropoffLat       Float?
  dropoffLng       Float?
  pattern          RecurrencePattern
  dayOfWeek        Int?
  dayOfMonth       Int?
  scheduledTime    String
  distanceMiles    Float?
  flatFare         Float?
  notes            String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  bookings         Booking[]
}

model CareHomeInvoice {
  id           String          @id @default(cuid())
  careHomeId   String
  careHome     CareHomeAccount @relation(fields: [careHomeId], references: [id])
  periodFrom   DateTime
  periodTo     DateTime
  dueDate      DateTime
  totalAmount  Float
  isPaid       Boolean         @default(false)
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  bookings     Booking[]
}
