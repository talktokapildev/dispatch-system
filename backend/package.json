    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.16.0",
    "axios": "^1.7.3",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.0",
    "expo-server-sdk": "^6.1.0",
